# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/levelup_campus

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM="LevelUp Campus <noreply@levelupcampus.com>"

# OTP
OTP_EXPIRY_MINUTES=10
OTP_COOLDOWN_SECONDS=60

# College Email Domain (comma-separated for multiple)
ALLOWED_EMAIL_DOMAINS=college.edu,university.ac.in,iit.ac.in

# Client URL (for CORS)
CLIENT_URL=http://localhost:5000
